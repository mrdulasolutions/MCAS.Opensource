# Build / generated outputs
# Track CSVs (transparency: every prediction goes into version control).
# Ignore SDF/SMI bundles, model checkpoints, and intermediate artifacts.
outputs/*.sdf
outputs/*.smi
outputs/structures/
outputs/reinvent_run/
outputs/*.ckpt
outputs/*.pt

# Vina docking artifacts — keep the per-ligand CSV results but skip the
# multi-MB receptor PDB / PDBQT and reference ligand files (they're
# downloadable from RCSB).
outputs/keap1_docking/4l7b.pdb
outputs/keap1_docking/4l7b_clean.pdb
outputs/keap1_docking/4l7b_1vv.pdb
outputs/keap1_docking/4l7b_receptor.pdbqt

# Vina + smina + obabel binaries (downloadable from upstream releases)
.tools/

# Caches
# Note: data/compounds/.smiles_cache.json is intentionally NOT ignored —
# committing the cache means CI runs survive transient PubChem outages
# (see June 2026 incident where PubChem briefly empty-returned three
# anchor compounds and broke refresh-pipeline.yml).
.cache/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# PyTDC downloads its raw training data to cwd/data/ — keep these out of git;
# they're rebuildable by anyone via the PyTDC API.
data/*.tab
data/*.tsv
data/*.csv.gz
data/oracle/
data/utils/

# Secrets
*.key
*.pem
.envrc

# Large model artifacts
*.ckpt
*.pt
*.bin
*.h5
*.safetensors
priors/
